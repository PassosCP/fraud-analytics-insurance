		annotation PBI_FormatHint = {"isDecimal":true}

	column 'Faixa de Risco' =
			
			SWITCH(
			    TRUE(),
			    'base_final_priorizacao'[score_fraude] <= 10, "00-10 (Baixíssimo)",
			    'base_final_priorizacao'[score_fraude] <= 20, "11-20 (Baixo)",
			    'base_final_priorizacao'[score_fraude] <= 40, "21-40 (Moderado)",
			    'base_final_priorizacao'[score_fraude] <= 60, "41-60 (Atenção)",
			    'base_final_priorizacao'[score_fraude] <= 80, "61-80 (Alto)",
			    'base_final_priorizacao'[score_fraude] <= 90, "81-90 (Crítico)",
			    "91-100 (Sindicância Imediata)"
			)
		lineageTag: 3e2dd6e7-1752-460b-bd27-1c65a78e9afb
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Status do Sinistro' = ```
			
			IF(
			    VALUE('base_final_priorizacao'[flag_fraude_confirmada]) = 1, 
			    "Fraude", 
			    "Regular"
			)
			```
		lineageTag: c124db30-9b1a-467c-945b-ecf605823447
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Data Ano' = YEAR('base_final_priorizacao'[data_ocorrencia])
		formatString: 0
		lineageTag: 7dc0fc04-90ed-445b-9cef-4b890431df76
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Data Mes' = FORMAT('base_final_priorizacao'[data_ocorrencia].[Ano], "MMMM")
		lineageTag: 767ae852-25c3-430a-ae37-7dcefd8e216f
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

