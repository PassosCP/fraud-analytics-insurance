table base_final_priorizacao
	lineageTag: 8291a0c4-c226-4263-b9cb-c1bf4445a130

	measure 'Qtd Sinistros por Risco' = COUNT('base_final_priorizacao'[id_sinistro])
		formatString: 0
		lineageTag: 15a44da9-3908-46f3-a459-17970d055e93

	measure 'Perda Evitada Potencial' = SUMX(FILTER(base_final_priorizacao, base_final_priorizacao[score_fraude] > 80), base_final_priorizacao[valor_reclamado])
		formatString: 0
		lineageTag: ae606b20-1559-41be-bbbb-baaa990c66cf

	measure 'Total Fraudes Identificadas Modelo' = ```
			
			CALCULATE(
			    COUNT('base_final_priorizacao'[id_sinistro]), 
			    'base_final_priorizacao'[score_fraude] >= 80
			)
			```
		formatString: 0
		lineageTag: 28189d09-b4e6-4ede-ad3f-984ec28201ad

	measure 'Taxa de Detecção de Fraude' =
			
			VAR Resultado = DIVIDE([Total Fraudes Identificadas Modelo], COUNT('base_final_priorizacao'[id_sinistro]))
			RETURN
			IF(ISBLANK(Resultado), 0, Resultado)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b77940f2-a684-443e-9eb6-b5d3b20ec50f

	measure 'Meta Detecção' = 0.20
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3190a67e-444a-4f61-807c-1846af3e0517

	measure 'Limite Minimo Gauge' = 0
		formatString: 0
		lineageTag: 3eac3005-9f7a-49fe-bc3c-87673df336e7

	measure 'Limite Maximo Gauge' = 0.40
		lineageTag: b316dd83-2278-451a-8dae-faf3262ccb44

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Qtd Fraudes Confirmadas' =
			
			CALCULATE(
			    COUNT('base_final_priorizacao'[id_sinistro]),
			    'base_final_priorizacao'[flag_fraude_confirmada] = 1
			)
		formatString: 0
		lineageTag: 567625cd-df9d-4c7f-adf1-fe04aef9d04c

	measure 'Valor em Risco' = CALCULATE(SUM('base_final_priorizacao'[valor_reclamado]), 'base_final_priorizacao'[score_fraude] >= 80)
		formatString: 0
		lineageTag: 74176adc-0120-4181-8aa6-178be037d8c4

	measure 'Fraudes Detectadas (Score > 80)' =
			
			CALCULATE(
			    [Qtd Fraudes Confirmadas],
			    'base_final_priorizacao'[score_fraude] >= 80
			)
		formatString: 0
		lineageTag: c4d6551e-8249-4f84-a34b-89dff14d098e

	measure 'Fraudes Não Detectadas (Falso Negativo)' =
			
			CALCULATE(
			    [Qtd Fraudes Confirmadas],
			    'base_final_priorizacao'[score_fraude] < 80
			)
		formatString: 0
		lineageTag: 0c5ecef3-fa27-4146-9099-dc3b818e4e95

